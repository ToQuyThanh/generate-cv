# ═══════════════════════════════════════════════════════════════════════════════
# generate-cv — Production Environment Variables
# Sao chép file này thành .env rồi điền giá trị thật:
#   cp .env.example .env
#
# ⚠️  KHÔNG commit file .env vào Git.
# ⚠️  Tất cả giá trị có nhãn [REQUIRED] PHẢI được điền trước khi chạy production.
# ═══════════════════════════════════════════════════════════════════════════════

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=production
APP_PORT=8080
APP_RELEASE=v1.0.0          # Dùng cho Sentry release tracking

# ── Database (PostgreSQL) ──────────────────────────────────────────────────────
DB_USER=generate_cv_user    # [REQUIRED] Đổi khỏi postgres default
DB_PASSWORD=CHANGE_ME       # [REQUIRED] Mật khẩu mạnh, ≥ 20 ký tự
DB_NAME=generate_cv
# DB_HOST và DB_PORT được override bởi docker-compose (dùng service name)
# Không cần điền ở đây khi chạy qua docker-compose

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME    # [REQUIRED] Để trống = không có auth (không khuyến nghị prod)
# REDIS_ADDR override bởi docker-compose

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_RANDOM_64_CHARS_MINIMUM  # [REQUIRED] Generate: openssl rand -hex 32
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# ── Google OAuth2 ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=           # [REQUIRED nếu dùng Google login]
GOOGLE_CLIENT_SECRET=       # [REQUIRED nếu dùng Google login]
GOOGLE_REDIRECT_URL=https://your-domain.com/api/v1/auth/google/callback

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://your-domain.com  # [REQUIRED] Domain production frontend

# Redirect URL sau khi đăng nhập thành công (có thể là dashboard hoặc homepage)
FRONTEND_URL=https://your-domain.com   # [REQUIRED] URL frontend

# ── Sentry (Error Tracking) ────────────────────────────────────────────────────
SENTRY_DSN=                 # Để trống = tắt Sentry

# ── Resend (Transactional Email) ──────────────────────────────────────────────
RESEND_API_KEY=             # [REQUIRED] Lấy tại https://resend.com → API Keys
                            # Để trống = dùng NoOpSender (chỉ log, không gửi email thật)
RESEND_FROM=CV Generator <noreply@yourdomain.com>  # [REQUIRED] Địa chỉ gửi đã xác minh trên Resend
RESEND_APP_NAME=CV Generator                       # Tên hiển thị trong email

# ── Frontend (Next.js build-time) ─────────────────────────────────────────────
# Các biến NEXT_PUBLIC_* được nhúng vào lúc build, không phải runtime
NEXT_PUBLIC_API_URL=https://your-domain.com   # [REQUIRED] URL public backend API
NEXT_PUBLIC_APP_URL=https://your-domain.com   # [REQUIRED] URL frontend
NEXT_PUBLIC_GOOGLE_CLIENT_ID=                 # Giống GOOGLE_CLIENT_ID ở trên


# Profile Processing Agent Service
AGENT_BASE_URL=http://localhost:8000
AGENT_TIMEOUT_SEC=30
AGENT_MAX_RETRIES=3
AGENT_RETRY_DELAY_SEC=1